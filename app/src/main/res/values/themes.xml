<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme – chỉ override màu chữ, an toàn 100% -->
    <style name="Base.Theme.Tip" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Màu chữ: trắng toàn app -->
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorHint">#888899</item>

        <!-- EditText text: trắng -->
        <item name="android:editTextColor">#FFFFFF</item>
        <item name="android:colorControlActivated">#735BF2</item>
        <item name="android:colorControlHighlight">#33735BF2</item>
    </style>

    <style name="Theme.Tip" parent="Base.Theme.Tip" />

    <!-- Dark Popup Menu Style for dropdowns -->
    <style name="DarkPopupMenuStyle" parent="ThemeOverlay.Material3.Dark">
        <item name="colorSurface">#1C1C2A</item>
        <item name="android:colorBackground">#1C1C2A</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <!-- For standard android.widget.PopupMenu -->
        <item name="android:popupBackground">#1C1C2A</item>
    </style>





    <style name="NumpadKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="CategoryCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="cardBackgroundColor">#1A1B29</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="CategoryContent">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="EmojiKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">24sp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>