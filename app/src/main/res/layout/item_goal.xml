<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    app:cardBackgroundColor="#1A1B29"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardBackgroundColor="#21233F"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <TextView
                    android:id="@+id/tv_goal_emoji"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="💻"
                    android:textSize="18sp"
                    android:gravity="center"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_goal_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Laptop"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_goal_target_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target: Jun 2026"
                    android:textColor="#8C8D99"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_goal_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="55%"
                android:textColor="#8288D8"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Progress bar container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="100">
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_progress_fill"
                android:layout_width="0dp"
                android:layout_weight="55"
                android:layout_height="match_parent"
                app:cardBackgroundColor="#8288D8"
                app:cardCornerRadius="3dp"
                app:cardElevation="0dp"/>
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_progress_empty"
                android:layout_width="0dp"
                android:layout_weight="45"
                android:layout_height="match_parent"
                app:cardBackgroundColor="#2D3042"
                app:cardCornerRadius="3dp"
                app:cardElevation="0dp"
                android:layout_marginStart="-6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="bottom">
            <TextView
                android:id="@+id/tv_saved_amount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₫8,200,000"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_target_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="of ₫15,000,000"
                android:textColor="#8C8D99"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
