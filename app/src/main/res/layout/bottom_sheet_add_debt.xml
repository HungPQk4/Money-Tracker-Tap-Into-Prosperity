<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface_white"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="28dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/border_color" />

    <!-- Sheet Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Thêm khoản nợ / vay"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Type Toggle -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_debt_type"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="20dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btn_type_i_owe">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_i_owe"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E53935"
            app:cornerRadius="12dp"
            android:textColor="#E53935"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:text="Mình nợ" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_lent"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#2E7D32"
            app:cornerRadius="12dp"
            android:textColor="#2E7D32"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:text="Cho vay" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:hint="Tên người liên quan"
        app:hintTextColor="@color/purple_primary"
        app:boxStrokeColor="@color/purple_primary"
        app:boxBackgroundColor="@color/bg_screen"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_debt_name"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="textPersonName"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Reason Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:hint="Lý do (VD: Vay mua xe)"
        app:hintTextColor="@color/purple_primary"
        app:boxStrokeColor="@color/purple_primary"
        app:boxBackgroundColor="@color/bg_screen"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_debt_reason"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="textCapSentences"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Due Date Selector Card -->
    <LinearLayout
        android:id="@+id/card_due_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        android:background="@drawable/bg_date_selector_default"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Calendar icon background pill -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_add_pill_purple"
            android:gravity="center">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_calendar_purple"
                app:tint="@color/white" />
        </LinearLayout>

        <!-- Labels -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày hẹn trả"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_due_date_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Chọn ngày..."
                android:textColor="@color/purple_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_chevron_right" />

    </LinearLayout>

    <!-- Amount Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_debt_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:hint="Số tiền (VND)"
        app:hintTextColor="#E53935"
        app:boxStrokeColor="#E53935"
        app:boxBackgroundColor="@color/bg_screen"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_debt_amount"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:inputType="numberDecimal"
            android:textColor="#E53935"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColorHint="@color/text_secondary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_debt"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Lưu khoản nợ"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#E53935"
        app:cornerRadius="14dp"
        app:elevation="4dp" />

</LinearLayout>
