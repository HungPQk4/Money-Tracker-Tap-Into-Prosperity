<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    android:clipToPadding="false"
    android:paddingBottom="90dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp">

        <include layout="@layout/header_analytics" />

        <!-- ═══════════════════════════════════════════════════════
             INCOME VS EXPENSE BAR CHART
        ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thu nhập vs Chi tiêu"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Biểu đồ 6 tháng gần nhất"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <!-- Bar Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal"
                    android:gravity="bottom|center_horizontal"
                    android:baselineAligned="false">

                    <!-- Month 1 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="bottom">
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_income_1" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#2DD3A1" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                            <Space android:layout_width="3dp" android:layout_height="wrap_content"/>
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_expense_1" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#E76E60" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tv_month_label_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T1" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Month 2 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="bottom">
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_income_2" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#2DD3A1" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                            <Space android:layout_width="3dp" android:layout_height="wrap_content"/>
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_expense_2" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#E76E60" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tv_month_label_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T2" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Month 3 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="bottom">
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_income_3" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#2DD3A1" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                            <Space android:layout_width="3dp" android:layout_height="wrap_content"/>
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_expense_3" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#E76E60" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tv_month_label_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T3" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Month 4 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="bottom">
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_income_4" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#2DD3A1" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                            <Space android:layout_width="3dp" android:layout_height="wrap_content"/>
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_expense_4" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#E76E60" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tv_month_label_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T4" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Month 5 -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="bottom">
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_income_5" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#2DD3A1" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                            <Space android:layout_width="3dp" android:layout_height="wrap_content"/>
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_expense_5" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#E76E60" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tv_month_label_5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T5" android:textColor="#6B7280" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Month 6 (Current) -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal" android:gravity="bottom">
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_income_6" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#2DD3A1" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                            <Space android:layout_width="3dp" android:layout_height="wrap_content"/>
                            <androidx.cardview.widget.CardView android:id="@+id/cv_bar_expense_6" android:layout_width="14dp" android:layout_height="0dp" app:cardBackgroundColor="#E76E60" app:cardCornerRadius="7dp" app:cardElevation="0dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/tv_month_label_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T6" android:textColor="#6A5AE0" android:textSize="11sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Chart Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#2DD3A1" app:cardElevation="0dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Thu nhập" android:textColor="#6B7280" android:textSize="12sp" />

                    <Space android:layout_width="24dp" android:layout_height="wrap_content"/>

                    <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#E76E60" app:cardElevation="0dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="Chi tiêu" android:textColor="#6B7280" android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════
             EXPENSE BY CATEGORY
        ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chi tiêu theo danh mục"
                    android:textColor="#1F2937"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Phân bổ chi tiêu tháng này"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Doughnut Chart Mockup -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="55dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:orientation="horizontal">
                                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#6A5AE0"/>
                                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#F2C94C"/>
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:orientation="horizontal">
                                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#2DD3A1"/>
                                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="#E76E60"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Inner Hole -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="30dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardElevation="2dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tổng"
                                    android:textColor="#9CA3AF"
                                    android:textSize="8sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₫5.5M"
                                    android:textColor="#1F2937"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>

                    <!-- Pie Chart Legends -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:orientation="vertical">

                        <!-- Legend 1: Food -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                            <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#E76E60" app:cardElevation="0dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:text="Ăn uống" android:textColor="#6B7280" android:textSize="13sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40%" android:textColor="#1F2937" android:textStyle="bold" android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Legend 2: Transport -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                            <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#6A5AE0" app:cardElevation="0dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:text="Di chuyển" android:textColor="#6B7280" android:textSize="13sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18%" android:textColor="#1F2937" android:textStyle="bold" android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Legend 3: Health -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:gravity="center_vertical">
                            <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#2DD3A1" app:cardElevation="0dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:text="Sức khỏe" android:textColor="#6B7280" android:textSize="13sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="13%" android:textColor="#1F2937" android:textStyle="bold" android:textSize="14sp" />
                        </LinearLayout>

                        <!-- Legend 4: Shopping -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                            <androidx.cardview.widget.CardView android:layout_width="10dp" android:layout_height="10dp" app:cardCornerRadius="5dp" app:cardBackgroundColor="#F2C94C" app:cardElevation="0dp"/>
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="10dp" android:text="Mua sắm" android:textColor="#6B7280" android:textSize="13sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="29%" android:textColor="#1F2937" android:textStyle="bold" android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════
             SUMMARY CARDS (Income / Expense / Net)
        ═══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Total Income -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▲ Thu"
                        android:textColor="#2DD3A1"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_analytics_income"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="₫0"
                        android:textColor="#1F2937"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total Expense -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▼ Chi"
                        android:textColor="#E76E60"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_analytics_expense"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="₫0"
                        android:textColor="#1F2937"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Transfer -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⇄ Chuyển khoản"
                        android:textColor="#3B82F6"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_analytics_transfer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="₫0"
                        android:textColor="#1F2937"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════
             AI INSIGHT CARD
        ═══════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#6A5AE0"
                    app:cardElevation="4dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="AI"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dự đoán chi tiêu"
                        android:textColor="#6A5AE0"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Với tốc độ hiện tại, bạn sẽ vượt ngân sách Ăn uống khoảng ₫1.2M trong tháng này. Hãy cân nhắc giảm chi tiêu!"
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
