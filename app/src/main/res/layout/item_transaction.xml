<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_transaction"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Category Icon Badge -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_tx_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardBackgroundColor="#F3F4F6"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tv_tx_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🍜"
                android:textSize="22sp" />

        </androidx.cardview.widget.CardView>

        <!-- Title + Subtitle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tx_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Phở Thìn"
                android:textColor="#1F2937"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Category pill -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_tx_category"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="#F3F4F6"
                    app:cardCornerRadius="11dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/tv_tx_category"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingHorizontal="8dp"
                        android:text="Ăn uống"
                        android:textColor="#4B5563"
                        android:textSize="11sp" />

                </androidx.cardview.widget.CardView>

                <!-- Time -->
                <TextView
                    android:id="@+id/tv_tx_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:15"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Amount + Wallet label -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end|center_vertical"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tx_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-₫75.000"
                android:textColor="#EF4444"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_tx_wallet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Tiền mặt"
                android:textColor="#4B5563"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
