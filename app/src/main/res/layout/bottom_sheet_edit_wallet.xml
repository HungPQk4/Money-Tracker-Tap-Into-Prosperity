<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A35"
        android:paddingBottom="40dp">

        <!-- Handle bar -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:background="#4D4D7A" />

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="Chỉnh sửa ví"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_close_edit_sheet"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="#2D2D50"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#9CA3AF" />
        </LinearLayout>

        <!-- Icon preview + color picker -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Icon preview -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_edit_icon_preview"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardBackgroundColor="#735BF2"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <TextView
                        android:id="@+id/tv_edit_icon_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="💳"
                        android:textSize="34sp" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Đổi icon"
                    android:textColor="#735BF2"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Color chips -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Màu sắc"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View android:id="@+id/edit_chip_color_purple"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#735BF2" />
                    <View android:id="@+id/edit_chip_color_blue"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#0EA5E9" />
                    <View android:id="@+id/edit_chip_color_pink"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#D946EF" />
                    <View android:id="@+id/edit_chip_color_green"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#22C55E" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View android:id="@+id/edit_chip_color_orange"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#F97316" />
                    <View android:id="@+id/edit_chip_color_red"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#EF4444" />
                    <View android:id="@+id/edit_chip_color_yellow"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#EAB308" />
                    <View android:id="@+id/edit_chip_color_teal"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:layout_margin="4dp" android:background="#14B8A6" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginHorizontal="20dp" android:layout_marginBottom="24dp"
            android:background="#2D2D50" />

        <!-- Wallet Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:text="Tên ví *"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:boxBackgroundColor="#252545"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#735BF2"
            app:hintTextColor="#735BF2"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_edit_wallet_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:color/transparent"
                android:hint="Tên ví"
                android:inputType="textCapSentences"
                android:textColor="#FFFFFF"
                android:textColorHint="#4B5563"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Balance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="8dp"
            android:text="Số dư hiện tại"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:boxBackgroundColor="#252545"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#735BF2"
            app:hintTextColor="#735BF2"
            app:prefixText="₫ "
            app:prefixTextColor="#735BF2"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_edit_wallet_balance"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:color/transparent"
                android:hint="0"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#4B5563"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Wallet Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:text="Loại ví"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/edit_chip_type_cash"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#252545"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💵 " android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tiền mặt" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/edit_chip_type_bank"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#252545"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏦 " android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ngân hàng" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/edit_chip_type_ewallet"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#252545"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💜 " android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ví điện tử" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/edit_chip_type_investment"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#252545"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📈 " android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đầu tư" android:textColor="#FFFFFF" android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Include in Total switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tính vào tổng tài sản"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Ví sẽ được tính vào số dư tổng"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_edit_include_in_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="#FFFFFF"
                app:trackDecorationTint="#735BF2" />
        </LinearLayout>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="#2D2D50" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <!-- Delete -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_edit_wallet_delete"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="12dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#2D1C1C"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🗑️"
                    android:textSize="22sp" />
            </androidx.cardview.widget.CardView>

            <!-- Save / Update -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_edit_wallet_save"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#735BF2"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Lưu thay đổi"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
